<policies>
	<inbound>
		<base />
		<rate-limit-by-key calls="300" renewal-period="60" counter-key="@(context.Subscription?.Key ?? &quot;anonymous&quot;)" remaining-calls-variable-name="rateLimitRemaining" total-calls-variable-name="rateLimitTotal" retry-after-variable-name="rateLimitRetryAfter" />
		<quota-by-key calls="250000" renewal-period="2628000" counter-key="@(context.Subscription?.Key ?? &quot;anonymous&quot;)" remaining-calls-variable-name="quotaRemaining" total-calls-variable-name="quotaTotal" />
		<!-- No endpoint gating: Professional tier has access to all endpoints -->
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>
