<policies>
	<inbound>
		<base />
		<set-variable name="rlLimit" value="500" />
		<rate-limit-by-key calls="@(int.Parse((string)context.Variables["rlLimit"]))" renewal-period="60" counter-key="@(context.Subscription?.Key ?? &quot;anonymous&quot;)" remaining-calls-header-name="X-RateLimit-Remaining" total-calls-header-name="X-RateLimit-Limit" retry-after-header-name="Retry-After" remaining-calls-variable-name="rlRemaining" />
		<quota-by-key calls="2000000" renewal-period="2628000" counter-key="@{
			var key = context.Subscription?.Key ?? &quot;anonymous&quot;;
			var name = context.Subscription?.Name ?? &quot;&quot;;
			var sep = name.LastIndexOf('|');
			var epoch = sep >= 0 ? name.Substring(sep + 1) : &quot;0&quot;;
			return key + &quot;|&quot; + epoch;
		}" />
		<!-- No endpoint gating: ATP tier has access to all endpoints -->
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>
