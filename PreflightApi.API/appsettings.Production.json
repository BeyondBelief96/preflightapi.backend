{
  "CloudStorage": {
    "UseManagedIdentity": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "NmsSettings": {
    "CacheDurationMinutes": 5,
    "DefaultRouteCorridorRadiusNm": 25,
    "RequestTimeoutSeconds": 30
  }
}
