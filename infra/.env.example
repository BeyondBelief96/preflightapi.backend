# Copy to .env.test or .env.prod and fill in values
# These are read by deploy.sh and consumed via readEnvironmentVariable() in .bicepparam files

# PostgreSQL
DB_ADMIN_PASSWORD=

# APIM
APIM_PUBLISHER_EMAIL=

# NOAA weather services
NOAA_API_KEY=

# NMS (NOTAM Management System) OAuth2 credentials
NMS_CLIENT_ID=
NMS_CLIENT_SECRET=

# APIM-to-API shared secret
GATEWAY_SECRET=

# Clerk JWT authority URL (e.g., https://your-clerk-instance.clerk.accounts.dev)
CLERK_AUTHORITY=
CLERK_SECRET_KEY=

# Certificate Renewal (Let's Encrypt via ACME)
CERTIFICATE_ACME_EMAIL=
CERTIFICATE_CERT_NAME=
CERTIFICATE_DOMAIN=
CERTIFICATE_ROOT_DOMAIN=

# Porkbun DNS (for ACME DNS-01 challenge)
PORKBUN_API_KEY=
PORKBUN_SECRET_API_KEY=

# Resend email notifications
RESEND_API_TOKEN=
RESEND_SEGMENT_ALL_ID=
RESEND_TOPIC_ALERTS_ID=

# Object ID of the GitHub deployment service principal (App Registration)
GITHUB_DEPLOYMENT_PRINCIPAL_ID=

# Object ID of the APIM management service principal (optional, PRD only)
APIM_SERVICE_PRINCIPAL_ID=
