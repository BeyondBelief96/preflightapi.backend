{
  "$schema": "nasr-schema-manifest-v1",
  "csvFile": "APT_CON.csv",
  "description": "Airport facility contact data from the FAA NASR 28-day subscription. Supplementary data merged into the Airport entity by SITE_NO.",
  "entity": "Airport",
  "supplementaryTo": "APT_BASE.csv",
  "mergeKey": "SITE_NO",
  "lastVerified": "2026-02-11",
  "columns": {
    "SITE_NO": {
      "entityProperty": "SiteNo",
      "dataType": "string",
      "required": true,
      "description": "Unique Site Number assigned by the FAA."
    },
    "EFF_DATE": {
      "entityProperty": "EffDate",
      "dataType": "date",
      "required": true,
      "description": "Effective date of the airport information."
    },
    "SITE_TYPE_CODE": {
      "entityProperty": "SiteTypeCode",
      "dataType": "string",
      "description": "Landing facility type code.",
      "enumeratedValues": ["A", "H", "S", "G", "U"]
    },
    "STATE_CODE": {
      "entityProperty": "StateCode",
      "dataType": "string",
      "description": "Two-letter USPS state code."
    },
    "ARPT_ID": {
      "entityProperty": "ArptId",
      "dataType": "string",
      "description": "FAA location identifier."
    },
    "CITY": {
      "entityProperty": "City",
      "dataType": "string",
      "description": "Associated city name."
    },
    "COUNTRY_CODE": {
      "entityProperty": "CountryCode",
      "dataType": "string",
      "description": "Two-letter country code."
    },
    "TITLE": {
      "entityProperty": "ContactTitle",
      "dataType": "string",
      "description": "Title of the facility contact (e.g., MANAGER, OWNER)."
    },
    "NAME": {
      "entityProperty": "ContactName",
      "dataType": "string",
      "description": "Facility contact name."
    },
    "ADDRESS1": {
      "entityProperty": "ContactAddress1",
      "dataType": "string",
      "description": "Contact address line 1."
    },
    "ADDRESS2": {
      "entityProperty": "ContactAddress2",
      "dataType": "string",
      "description": "Contact address line 2."
    },
    "TITLE_CITY": {
      "entityProperty": "ContactCity",
      "dataType": "string",
      "description": "Contact city."
    },
    "STATE": {
      "entityProperty": "ContactState",
      "dataType": "string",
      "description": "Contact state."
    },
    "ZIP_CODE": {
      "entityProperty": "ContactZipCode",
      "dataType": "string",
      "description": "Contact ZIP code."
    },
    "ZIP_PLUS_FOUR": {
      "entityProperty": "ContactZipPlusFour",
      "dataType": "string",
      "description": "Contact ZIP+4 code."
    },
    "PHONE_NO": {
      "entityProperty": "ContactPhoneNumber",
      "dataType": "string",
      "description": "Contact phone number."
    }
  }
}
