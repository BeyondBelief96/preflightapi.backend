          "captured": true,
          "description": "Hazard severity"
        }
      }
    },
    "area": {
      "description": "Geographic polygon boundary (repeating, with point child elements)",
      "attributes": {
        "num_points": {
          "entityProperty": "Area.NumPoints",
          "dataType": "int",
