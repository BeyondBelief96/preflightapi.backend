{
  "$schema": "avwx-schema-manifest-v1",
  "xmlRootElement": "AIRSIGMET",
  "entity": "Sigmet",
  "lastVerified": "2026-02-11",
  "elements": {
    "raw_text": {
      "entityProperty": "RawText",
      "dataType": "string",
      "required": false,
      "openApiProperty": "rawAirSigmet",
      "captured": true,
