    },
    "valid_time_from": {
      "entityProperty": "ValidTimeFrom",
      "dataType": "string",
      "required": true,
      "openApiProperty": "validTimeFrom",
      "captured": true,
      "description": "Advisory validity period start"
    },
    "valid_time_to": {
      "entityProperty": "ValidTimeTo",
      "dataType": "string",
      "required": true,
      "openApiProperty": "validTimeTo",
      "captured": true,
      "description": "Advisory validity period end"
