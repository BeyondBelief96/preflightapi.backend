      "description": "Temperature forecast within forecast period (child elements)",
      "elements": {
        "valid_time": {
          "entityProperty": "Temperature.ValidTime",
          "dataType": "string",
          "required": true,
          "openApiProperty": "validTime",
          "captured": true,
          "description": "Temperature valid time"
        },
        "sfc_temp_c": {
          "entityProperty": "Temperature.SfcTempC",
          "dataType": "float",
          "required": false,
          "openApiProperty": "sfcTemp",
          "captured": true,
          "description": "Surface temperature in Celsius"
