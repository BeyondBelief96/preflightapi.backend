        "max_temp_c": {
          "entityProperty": "Temperature.MaxTempC",
          "dataType": "string",
          "required": false,
          "openApiProperty": "maxTemp",
          "captured": true,
          "description": "Maximum temperature in Celsius"
        },
        "min_temp_c": {
          "entityProperty": "Temperature.MinTempC",
          "dataType": "string",
          "required": false,
          "openApiProperty": "minTemp",
          "captured": true,
          "description": "Minimum temperature in Celsius"
        }
      }
    }
  }
}
