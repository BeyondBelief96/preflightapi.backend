      "description": "TAF forecast period (repeating element with child elements)",
      "elements": {
        "fcst_time_from": {
          "entityProperty": "Forecast.FcstTimeFrom",
          "dataType": "string",
          "required": true,
          "openApiProperty": "timeFrom",
          "captured": true,
          "description": "Forecast period start time"
        },
        "fcst_time_to": {
          "entityProperty": "Forecast.FcstTimeTo",
          "dataType": "string",
          "required": true,
          "openApiProperty": "timeTo",
          "captured": true,
          "description": "Forecast period end time"
        },
        "change_indicator": {
          "entityProperty": "Forecast.ChangeIndicator",
          "dataType": "string",
          "required": false,
          "openApiProperty": "change",
          "captured": true,
          "description": "Change indicator: FM, BECMG, TEMPO, PROB"
        },
        "time_becoming": {
          "entityProperty": "Forecast.TimeBecoming",
          "dataType": "string",
          "required": false,
          "openApiProperty": "timeBecoming",
          "captured": true,
          "description": "BECMG completion time"
        },
        "probability": {
          "entityProperty": "Forecast.Probability",
          "dataType": "int",
          "required": false,
          "openApiProperty": "probability",
          "captured": true,
          "description": "Probability percentage (30 or 40)"
