          "entityProperty": "Forecast.WindGustKt",
          "dataType": "int",
          "required": false,
          "openApiProperty": "wgst",
          "captured": true,
          "description": "Wind gust speed in knots"
        },
        "wind_shear_hgt_ft_agl": {
          "entityProperty": "Forecast.WindShearHgtFtAgl",
          "dataType": "short",
          "required": false,
          "openApiProperty": "wshearHgt",
          "captured": true,
          "description": "Wind shear height in feet AGL"
        },
        "wind_shear_dir_degrees": {
          "entityProperty": "Forecast.WindShearDirDegrees",
          "dataType": "short",
          "required": false,
          "openApiProperty": "wshearDir",
          "captured": true,
          "description": "Wind shear direction in degrees"
        },
        "wind_shear_speed_kt": {
          "entityProperty": "Forecast.WindShearSpeedKt",
          "dataType": "int",
          "required": false,
          "openApiProperty": "wshearSpd",
          "captured": true,
          "description": "Wind shear speed in knots"
        },
        "visibility_statute_mi": {
          "entityProperty": "Forecast.VisibilityStatuteMi",
          "dataType": "string",
          "required": false,
          "openApiProperty": "visib",
          "captured": true,
          "description": "Visibility in statute miles"
        },
        "altim_in_hg": {
          "entityProperty": "Forecast.AltimInHg",
          "dataType": "float",
          "required": false,
          "openApiProperty": "altim",
          "captured": true,
          "description": "Altimeter setting in inches of mercury"
        },
        "vert_vis_ft": {
          "entityProperty": "Forecast.VertVisFt",
          "dataType": "short",
          "required": false,
          "openApiProperty": "vertVis",
          "captured": true,
          "description": "Vertical visibility in feet"
        },
        "wx_string": {
          "entityProperty": "Forecast.WxString",
          "dataType": "string",
          "required": false,
          "openApiProperty": "wxString",
          "captured": true,
          "description": "Weather phenomena string"
        },
        "not_decoded": {
          "entityProperty": "Forecast.NotDecoded",
          "dataType": "string",
          "required": false,
          "openApiProperty": "notDecoded",
          "captured": true,
          "description": "Unparsed TAF text"
        },
        "sky_condition": {
          "entityProperty": "Forecast.SkyConditions",
          "dataType": "collection",
          "required": false,
          "openApiProperty": "clouds",
          "captured": true,
          "description": "Sky condition layers within forecast (attribute-based)"
        },
        "turbulence_condition": {
          "entityProperty": "Forecast.TurbulenceConditions",
          "dataType": "collection",
          "required": false,
          "openApiProperty": "turb",
          "captured": true,
          "description": "Turbulence conditions within forecast (attribute-based)"
        },
        "icing_condition": {
          "entityProperty": "Forecast.IcingConditions",
          "dataType": "collection",
          "required": false,
          "openApiProperty": "icing",
          "captured": true,
          "description": "Icing conditions within forecast (attribute-based)"
        },
        "temperature": {
          "entityProperty": "Forecast.Temperature",
          "dataType": "collection",
          "required": false,
          "openApiProperty": "temp",
          "captured": true,
          "description": "Temperature forecasts within forecast period"
        }
      }
    },
    "sky_condition": {
      "description": "Sky condition layer within forecast (uses attributes)",
      "attributes": {
        "sky_cover": {
          "entityProperty": "SkyCondition.SkyCover",
          "dataType": "string",
          "required": true,
          "openApiProperty": "cover",
          "captured": true,
          "description": "Sky cover type: SKC, CLR, FEW, SCT, BKN, OVC"
        },
        "cloud_base_ft_agl": {
          "entityProperty": "SkyCondition.CloudBaseFtAgl",
          "dataType": "int",
          "required": false,
          "openApiProperty": "base",
          "captured": true,
          "description": "Cloud base in feet AGL"
        },
        "cloud_type": {
          "entityProperty": "SkyCondition.CloudType",
          "dataType": "string",
          "required": false,
          "openApiProperty": "type",
          "captured": true,
          "description": "Cloud type: CB or TCU"
        }
      }
    },
    "turbulence_condition": {
      "description": "Turbulence condition within forecast (uses attributes)",
      "attributes": {
        "turbulence_intensity": {
          "entityProperty": "TurbulenceCondition.TurbulenceIntensity",
          "dataType": "string",
          "required": false,
