        "turbulence_min_alt_ft_agl": {
          "entityProperty": "TurbulenceCondition.TurbulenceMinAltFtAgl",
          "dataType": "int",
          "required": false,
          "openApiProperty": "minAlt",
          "captured": true,
          "description": "Turbulence bottom altitude in feet AGL"
        },
        "turbulence_max_alt_ft_agl": {
          "entityProperty": "TurbulenceCondition.TurbulenceMaxAltFtAgl",
          "dataType": "int",
          "required": false,
          "openApiProperty": "maxAlt",
          "captured": true,
          "description": "Turbulence top altitude in feet AGL"
        }
      }
    },
    "icing_condition": {
      "description": "Icing condition within forecast (uses attributes)",
      "attributes": {
        "icing_intensity": {
          "entityProperty": "IcingCondition.IcingIntensity",
          "dataType": "string",
          "required": false,
          "openApiProperty": "intensity",
          "captured": true,
          "description": "Icing intensity code 0-9"
        },
        "icing_min_alt_ft_agl": {
          "entityProperty": "IcingCondition.IcingMinAltFtAgl",
          "dataType": "int",
          "required": false,
          "openApiProperty": "minAlt",
          "captured": true,
          "description": "Icing bottom altitude in feet AGL"
        },
        "icing_max_alt_ft_agl": {
          "entityProperty": "IcingCondition.IcingMaxAltFtAgl",
          "dataType": "int",
          "required": false,
          "openApiProperty": "maxAlt",
          "captured": true,
          "description": "Icing top altitude in feet AGL"
        }
      }
