{
  "$schema": "avwx-schema-manifest-v1",
  "xmlRootElement": "TAF",
  "entity": "Taf",
  "lastVerified": "2026-02-11",
  "elements": {
    "raw_text": {
      "entityProperty": "RawText",
      "dataType": "string",
      "required": false,
      "openApiProperty": "rawTAF",
      "captured": true,
      "description": "Raw TAF text"
    },
    "station_id": {
      "entityProperty": "StationId",
      "dataType": "string",
      "required": true,
      "openApiProperty": "icaoId",
      "captured": true,
      "description": "ICAO station identifier"
    },
    "issue_time": {
      "entityProperty": "IssueTime",
      "dataType": "string",
      "required": true,
      "openApiProperty": "issueTime",
      "captured": true,
      "description": "ISO 8601 TAF issuance time"
    },
    "bulletin_time": {
      "entityProperty": "BulletinTime",
      "dataType": "string",
      "required": false,
      "openApiProperty": "bulletinTime",
      "captured": true,
      "description": "ISO 8601 official bulletin time"
    },
    "valid_time_from": {
      "entityProperty": "ValidTimeFrom",
      "dataType": "string",
      "required": true,
      "openApiProperty": "validTimeFrom",
      "captured": true,
      "description": "ISO 8601 validity period start"
    },
    "valid_time_to": {
      "entityProperty": "ValidTimeTo",
      "dataType": "string",
      "required": true,
      "openApiProperty": "validTimeTo",
      "captured": true,
      "description": "ISO 8601 validity period end"
    },
    "remarks": {
      "entityProperty": "Remarks",
      "dataType": "string",
      "required": false,
      "openApiProperty": "remarks",
      "captured": true,
      "description": "TAF remarks"
    },
    "latitude": {
      "entityProperty": "Latitude",
      "dataType": "float",
      "required": true,
      "openApiProperty": "lat",
      "captured": true,
      "description": "Station latitude in decimal degrees"
    },
    "longitude": {
      "entityProperty": "Longitude",
      "dataType": "float",
      "required": true,
      "openApiProperty": "lon",
      "captured": true,
      "description": "Station longitude in decimal degrees"
    },
    "elevation_m": {
      "entityProperty": "ElevationM",
      "dataType": "float",
      "required": false,
      "openApiProperty": "elev",
      "captured": true,
      "description": "Station elevation in meters"
    }
